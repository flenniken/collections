"use strict";

// Work with Push Subscriptions
//
// Run from the collections container:
//
// cd ~/collections
// node scripts/notification.js -h
//
// Web Push Docs:
// https://developer.mozilla.org/en-US/docs/Web/API/Push_API
// https://web.dev/articles/push-notifications-overview

if (!process.env.coder_env) {
  console.log("Run from the Collection's docker environment.")
  return
}

const webPush = require('web-push');
const { Command } = require('commander');

// Define the command line options.
const program = new Command();
program.option('-v, --vapid',
  'Generate VAPID public and private keys used to send push notifications.')

// Get the options specified on the command line.
program.parse(process.argv)
const options = program.opts();

if (options.vapid) {
  // Generate VAPID keys and show them in the console.
  const vapidKeys = webPush.generateVAPIDKeys();
  console.log(`VAPID Public:

${vapidKeys.publicKey}

VAPID Private:

${vapidKeys.privateKey}
`)
}
else
{
  console.log("Run with -h to see the available options.")
}
