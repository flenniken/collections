#!/usr/bin/env node

"use strict"

// Work with Push Subscriptions
//
// Run from the collections container:
//
// cd ~/collections
// scripts/notification -h
//
// Web Push Docs:
// https://developer.mozilla.org/en-US/docs/Web/API/Push_API
// https://web.dev/articles/push-notifications-overview
//
// Push JSON file (-p/--push <file>):
//
//   endpoint       (required) Push service URL from PushSubscription.toJSON()
//   keys           (required) object with:
//     p256dh       (required) client public key
//     auth         (required) authentication secret
//   subject        (required) contact email for the VAPID subject
//   title          notification title (at least one of title or body required)
//   body           notification body (at least one of title or body required)
//
// Subscription JSON file (-s/--save <file>):
//
//   userId         (required) Cognito user id — must match tmp/tokens.json
//   endpoint       (required) Push service URL
//   keys           (required) object with p256dh and auth
//
// Auth for --save:
//
//   POST /subscriptions via API Gateway using the access token from
//   tmp/tokens.json (Authorization Bearer). API Gateway validates the
//   token, invokes the save-subscription Lambda, which writes to DynamoDB.
//   Create tokens with: scripts/login-flow -g <code> or -r
//
// VAPID keys (~/.aws/vapid, [VAPID] section):
//
//   public: VAPID public key (must match the key used when creating the subscription)
//   private: VAPID private key
//   subject: contact email (required for --publish)
//
// Do not store VAPID keys in ~/.aws/credentials; boto3 cannot parse them there.
// DynamoDB:
//
//   table name = TABLE_NAME constant below
//   region     = region from ~/.aws/config [default] section
//
// API Gateway (created by --configure):
//
//   REST API name = API_NAME
//   POST /subscriptions with Cognito authorizer (Lambda wired by --deploy)
//   OPTIONS /subscriptions for CORS preflight from localhost and production
//
// Publish (--publish <user> <title>):
//
//   user           Cognito user id, or "all" for every subscriber
//   title          Collection title shown in the push notification
//   VAPID subject  contact email in ~/.aws/vapid [VAPID] section
//
// Deploy Lambda (--deploy <name>):
//
//   save-subscription -- deploy the zip and wire POST /subscriptions
//
// Build and test before deploy:
//   node scripts/testSaveSubscription.js
//   env/lambda/save-subscription/make-js-lambda-zip
//   scripts/notification --deploy save-subscription
//
// Deploy requires AWSLambda_FullAccess on the container IAM user.
// Lambda also needs an execution role (collections-lambda) created in
// the IAM console. See docs/aws-config.md.

if (!process.env.coder_env) {
  console.log("Run from the Collection's docker environment.")
  exit1()
}

const fs = require('fs')
const os = require('os')
const path = require('path')
const webPush = require('web-push')
const { Command } = require('commander')
const {
  CreateTableCommand,
  DescribeTableCommand,
  DynamoDBClient,
} = require('@aws-sdk/client-dynamodb')
const {
  DynamoDBDocumentClient,
  DeleteCommand,
  ScanCommand,
} = require('@aws-sdk/lib-dynamodb')
const {
  APIGatewayClient,
  CreateAuthorizerCommand,
  CreateDeploymentCommand,
  CreateResourceCommand,
  CreateRestApiCommand,
  GetAuthorizersCommand,
  GetMethodCommand,
  GetResourcesCommand,
  GetRestApisCommand,
  PutGatewayResponseCommand,
  PutIntegrationCommand,
  PutIntegrationResponseCommand,
  PutMethodCommand,
  PutMethodResponseCommand,
  UpdateGatewayResponseCommand,
  UpdateIntegrationResponseCommand,
  UpdateMethodResponseCommand,
} = require('@aws-sdk/client-api-gateway')
const {
  STSClient,
  GetCallerIdentityCommand,
} = require('@aws-sdk/client-sts')

const AWS_CREDENTIALS = path.join(os.homedir(), '.aws', 'credentials')
const AWS_VAPID = path.join(os.homedir(), '.aws', 'vapid')
const AWS_CONFIG = path.join(os.homedir(), '.aws', 'config')
const AWS_SETTINGS = path.join(process.cwd(), 'env', 'aws-settings.json')
const TOKENS_FILE = path.join(process.cwd(), 'tmp', 'tokens.json')
const TABLE_NAME = 'collections-push-subscriptions'
const API_NAME = 'collections-push-subscriptions'
const API_STAGE = 'prod'
const API_RESOURCE = 'subscriptions'
const API_AUTH_SCOPE = 'aws.cognito.signin.user.admin'
const LAMBDA_EXECUTION_ROLE = 'collections-lambda'

// Push services return 410 Gone when a subscription has expired or the
// user unsubscribed. Some services return 404 for an invalid endpoint.
const EXPIRED_SUBSCRIPTION_STATUS_CODES = new Set([410, 404])

// Lambda functions that can be deployed with --deploy.
const LAMBDA_DEPLOYS = {
  'save-subscription': {
    functionName: 'save-subscription',
    handler: 'saveSubscription.handler',
    description: 'Save Web Push subscriptions for Collections.',
    apiIntegration: {
      httpMethod: 'POST',
      resourcePath: `/${API_RESOURCE}`,
    },
  },
}

const program = new Command()
program
  .option('-v, --vapid',
    'Generate VAPID public and private keys used to send push notifications.')
  .option('-p, --push <file>',
    'Send a push notification.')
  .option('--publish <user> <title>',
    'Send a collection publish notification to one user or all.')
  .option('-s, --save <file>',
    'Save a push subscription via API Gateway, Lambda, and DynamoDB.')
  .option('--configure',
    'Create the DynamoDB table and API Gateway for push subscriptions.')
  .option('-g, --get-subscriptions [json]',
    'List push subscriptions one per line. Use json for listing them in JSON format with more details.')
  .option('--deploy <name>',
    'Deploy a notification Lambda function (e.g. save-subscription).')

function exit1(message) {
  // Exit the process with a return code of 1.
  if (message)
    console.error(message)
  process.exit(1)
}

function readFile(filename, errorMessage) {
  // Read the file. If there is an error, log the message to the
  // console and exit the process.
  try {
    return fs.readFileSync(filename, 'utf8')
  } catch (error) {
    if (!errorMessage)
      errorMessage = `Unable to read ${filename}.`
    exit1(errorMessage)
  }
}

function parseIniSection(text, sectionName) {
  // Return the key value pairs from the named section of an ini file.
  // Supports both "key: value" and "key = value" forms.
  const values = {}
  let inSection = false
  for (const line of text.split('\n')) {
    if (/^\[/.test(line)) {
      inSection = line.trim().toLowerCase() === `[${sectionName.toLowerCase()}]`
      continue
    }
    if (!inSection)
      continue
    const match = line.match(/^\s*([^=:\s]+)\s*[:=]\s*(.+)\s*$/)
    if (match)
      values[match[1]] = match[2].trim()
  }
  return values
}

function loadVapidCredentials() {
  // Read the VAPID keys from ~/.aws/vapid ([VAPID] section).
  // Keep VAPID keys out of ~/.aws/credentials so boto3 can parse that file.
  const text = readFile(AWS_VAPID,
    `Unable to read ${AWS_VAPID}. Run: scripts/notification -v`)
  const credentials = parseIniSection(text, 'VAPID')
  if (!credentials.public || !credentials.private)
    exit1(`${AWS_VAPID} is missing a [VAPID] section with public and private keys.`)
  return credentials
}

function loadVapidSubject() {
  // Return the VAPID contact email from the [VAPID] section.
  const credentials = loadVapidCredentials()
  errorExit(!credentials.subject,
    `${AWS_VAPID} [VAPID] section is missing subject (contact email).`)
  return credentials.subject
}

function loadAwsRegion() {
  // Read the region from the [default] section of ~/.aws/config.
  const text = readFile(AWS_CONFIG,
    `Unable to read ${AWS_CONFIG}. Run aws configure to set the region.`)
  const config = parseIniSection(text, 'default')
  if (!config.region)
    exit1(`${AWS_CONFIG} is missing region in the [default] section.`)
  return config.region
}

function loadAwsSettings() {
  // Read Cognito settings from env/aws-settings.json.
  const data = JSON.parse(readFile(AWS_SETTINGS,
    `Unable to read ${AWS_SETTINGS}. Run: scripts/cognito -w`))
  errorExit(!data.settings?.userPoolId,
    `${AWS_SETTINGS} is missing settings.userPoolId.`)
  errorExit(!data.settings?.client_id,
    `${AWS_SETTINGS} is missing settings.client_id.`)
  return data.settings
}

function updateAwsSettingsSubscriptionsUrl(url) {
  // Add the push subscriptions API URL to env/aws-settings.json.
  const data = JSON.parse(readFile(AWS_SETTINGS,
    `Unable to read ${AWS_SETTINGS}. Run: scripts/cognito -w`))
  errorExit(!data.settings,
    `${AWS_SETTINGS} is missing settings.`)
  data.settings.subscriptions_api_url = url
  fs.writeFileSync(AWS_SETTINGS, JSON.stringify(data, null, 2) + '\n')
  console.log(`Updated ${AWS_SETTINGS} with subscriptions_api_url.`)
}

function loadAccessToken() {
  // Read the Cognito access token from tmp/tokens.json.
  const data = JSON.parse(readFile(TOKENS_FILE,
    `Unable to read ${TOKENS_FILE}. Run: scripts/login-flow -g <code> or -r`))
  errorExit(!data.access_token,
    `${TOKENS_FILE} is missing access_token.`)
  return data.access_token
}

function tokenUserIdFromAccessToken(accessToken) {
  // Return the Cognito user id from an access token JWT payload.
  const payload = JSON.parse(
    Buffer.from(accessToken.split('.')[1], 'base64url').toString())
  errorExit(!payload.username,
    'access_token is missing username claim.')
  return payload.username
}

function errorExit(condition, errorMessage) {
  // If the condition is true, show the error message and exit.
  if (condition)
    exit1(errorMessage)
}

function loadPushFile(file) {
  // Read the push JSON file and return an object containing its
  // values. If an error happens, show an error message and exit.
  const data = JSON.parse(readFile(file))

  errorExit(!data.endpoint, 'Push file is missing endpoint.')
  errorExit(!data.keys?.p256dh, 'Push file is missing keys.p256dh.')
  errorExit(!data.keys?.auth, 'Push file is missing keys.auth.')

  const { subject, title, body, ...subscription } = data
  return { subscription, subject, title, body }
}

function loadSubscriptionFile(file) {
  // Read the subscription JSON file and return its values. If an
  // error happens, show an error message and exit.
  const data = JSON.parse(readFile(file))

  errorExit(!data.userId, 'Subscription file is missing userId.')
  errorExit(!data.endpoint, 'Subscription file is missing endpoint.')
  errorExit(!data.keys?.p256dh, 'Subscription file is missing keys.p256dh.')
  errorExit(!data.keys?.auth, 'Subscription file is missing keys.auth.')

  return data
}

function dynamoClient(region) {
  // Return a DynamoDB client for the given region.
  return new DynamoDBClient({ region })
}

function docClient(region) {
  // Return a DynamoDB document client for the given region.
  return DynamoDBDocumentClient.from(dynamoClient(region))
}

function apiGatewayClient(region) {
  // Return an API Gateway client for the given region.
  return new APIGatewayClient({ region })
}

function requireHomeModule(moduleName) {
  // Load a node module installed in ~/node_modules (see env/debian/Dockerfile).
  const modulePath = path.join(os.homedir(), 'node_modules', moduleName)
  if (!fs.existsSync(modulePath)) {
    exit1(`Cannot find module '${moduleName}'. Update container packages:\n` +
      '  cp ~/collections/env/debian/package.json ~/package.json\n' +
      '  npm install')
  }
  return require(modulePath)
}

function deploySdk() {
  // Load Lambda and IAM SDK modules when --deploy runs.
  const {
    LambdaClient,
    CreateFunctionCommand,
    GetFunctionCommand,
    UpdateFunctionCodeCommand,
    GetFunctionConfigurationCommand,
    AddPermissionCommand,
  } = requireHomeModule('@aws-sdk/client-lambda')
  const {
    IAMClient,
    GetRoleCommand,
  } = requireHomeModule('@aws-sdk/client-iam')
  return {
    LambdaClient,
    CreateFunctionCommand,
    GetFunctionCommand,
    UpdateFunctionCodeCommand,
    GetFunctionConfigurationCommand,
    AddPermissionCommand,
    IAMClient,
    GetRoleCommand,
  }
}

function lambdaClient(region) {
  // Return a Lambda client for the given region.
  const { LambdaClient } = deploySdk()
  return new LambdaClient({ region })
}

function iamClient() {
  // Return an IAM client (IAM is a global service).
  const { IAMClient } = deploySdk()
  return new IAMClient({})
}

async function getAccountId(region) {
  // Return the AWS account id for the current credentials.
  const sts = new STSClient({ region })
  const response = await sts.send(new GetCallerIdentityCommand({}))
  return response.Account
}

function vapidSubject(email) {
  // Return the VAPID subject, adding mailto: when needed.
  return email.includes(':') ? email : `mailto:${email}`
}

function formatPushError(error) {
  // Return a formatted error message from a web-push error.
  let message = error.message
  if (error.statusCode)
    message += ` (${error.statusCode})`
  if (error.body)
    message += `\n${error.body}`
  return message
}

function isExpiredSubscriptionError(error) {
  // Return true when the push endpoint is permanently invalid.
  return EXPIRED_SUBSCRIPTION_STATUS_CODES.has(error.statusCode)
}

async function deleteSubscription(userId, endpoint) {
  // Remove a push subscription from DynamoDB.
  const client = docClient(loadAwsRegion())
  await client.send(new DeleteCommand({
    TableName: TABLE_NAME,
    Key: { userId, endpoint },
  }))
}

async function removeExpiredSubscription(userId, endpoint) {
  // Delete a stale subscription after a 410 or 404 push error.
  await deleteSubscription(userId, endpoint)
  console.log(
    `Removed expired subscription for ${userId} ${shortEndpoint(endpoint)}`
  )
}

async function waitForTableActive(client, tableName) {
  // Wait until the DynamoDB table status is ACTIVE.
  for (;;) {
    const response = await client.send(new DescribeTableCommand({ TableName: tableName }))
    const status = response.Table?.TableStatus
    if (status === 'ACTIVE') {
      console.log('Table is active.')
      return
    }
    console.log(`Table status: ${status}. Waiting...`)
    await new Promise(resolve => setTimeout(resolve, 2000))
  }
}

async function configureDynamoTable(region) {
  // Create the DynamoDB table for push subscriptions if needed.
  const client = dynamoClient(region)

  try {
    await client.send(new DescribeTableCommand({ TableName: TABLE_NAME }))
    console.log(`Table ${TABLE_NAME} already exists.`)
  } catch (error) {
    if (error.name !== 'ResourceNotFoundException')
      throw error

    console.log(`Creating table ${TABLE_NAME} in ${region}.`)
    await client.send(new CreateTableCommand({
      TableName: TABLE_NAME,
      KeySchema: [
        { AttributeName: 'userId', KeyType: 'HASH' },
        { AttributeName: 'endpoint', KeyType: 'RANGE' },
      ],
      AttributeDefinitions: [
        { AttributeName: 'userId', AttributeType: 'S' },
        { AttributeName: 'endpoint', AttributeType: 'S' },
      ],
      BillingMode: 'PAY_PER_REQUEST',
    }))
    await waitForTableActive(client, TABLE_NAME)
  }
}

async function findRestApi(client, name) {
  // Return the REST API with the given name, or null.
  let position
  do {
    const response = await client.send(new GetRestApisCommand({
      limit: 500,
      position,
    }))
    const match = (response.items ?? []).find(api => api.name === name)
    if (match)
      return match
    position = response.position
  } while (position)
  return null
}

async function findOrCreateRestApi(client) {
  // Return the push subscriptions REST API, creating it if needed.
  const existing = await findRestApi(client, API_NAME)
  if (existing) {
    console.log(`API Gateway ${API_NAME} already exists (${existing.id}).`)
    return existing
  }

  console.log(`Creating API Gateway REST API ${API_NAME}.`)
  return client.send(new CreateRestApiCommand({
    name: API_NAME,
    description: 'Save Web Push subscriptions for Collections.',
    endpointConfiguration: { types: ['REGIONAL'] },
  }))
}

async function findOrCreateAuthorizer(client, restApiId, userPoolArn) {
  // Return the Cognito authorizer for the API, creating it if needed.
  const response = await client.send(new GetAuthorizersCommand({
    restApiId,
    limit: 100,
  }))
  const existing = (response.items ?? []).find(item => item.name === 'cognito')
  if (existing) {
    console.log(`Cognito authorizer already exists (${existing.id}).`)
    return existing
  }

  console.log('Creating Cognito authorizer.')
  return client.send(new CreateAuthorizerCommand({
    restApiId,
    name: 'cognito',
    type: 'COGNITO_USER_POOLS',
    providerARNs: [userPoolArn],
    identitySource: 'method.request.header.Authorization',
  }))
}

async function findOrCreateSubscriptionsResource(client, restApiId) {
  // Return the /subscriptions resource, creating it if needed.
  const response = await client.send(new GetResourcesCommand({
    restApiId,
    limit: 500,
  }))
  const resources = response.items ?? []
  const existing = resources.find(item => item.path === `/${API_RESOURCE}`)
  if (existing) {
    console.log(`Resource /${API_RESOURCE} already exists.`)
    return existing
  }

  const root = resources.find(item => item.path === '/')
  errorExit(!root, 'API Gateway root resource not found.')

  console.log(`Creating resource /${API_RESOURCE}.`)
  return client.send(new CreateResourceCommand({
    restApiId,
    parentId: root.id,
    pathPart: API_RESOURCE,
  }))
}

async function methodExists(client, restApiId, resourceId, httpMethod) {
  // Return true if the method already exists on the resource.
  try {
    await client.send(new GetMethodCommand({
      restApiId,
      resourceId,
      httpMethod,
    }))
    return true
  } catch (error) {
    if (error.name === 'NotFoundException')
      return false
    throw error
  }
}

async function ensurePostSubscriptionsMethod(client, restApiId, resourceId, authorizerId) {
  // Create POST /subscriptions with Cognito auth. Lambda is wired by --deploy.
  if (await methodExists(client, restApiId, resourceId, 'POST')) {
    console.log('POST /subscriptions already exists.')
    return
  }

  console.log('Creating POST /subscriptions with Cognito authorizer.')
  await client.send(new PutMethodCommand({
    restApiId,
    resourceId,
    httpMethod: 'POST',
    authorizationType: 'COGNITO_USER_POOLS',
    authorizerId,
    authorizationScopes: [API_AUTH_SCOPE],
  }))
}

function responseParameterPatches(responseParameters) {
  // Return API Gateway patch operations for response parameter updates.
  return Object.entries(responseParameters).map(([name, value]) => ({
    op: 'replace',
    path: `/responseParameters/${name}`,
    value: String(value),
  }))
}

function isAlreadyExistsError(error) {
  // Return true when API Gateway reports an existing method response.
  const message = error.message || ''
  return error.name === 'ConflictException' || message.includes('already exists')
}

async function putOrUpdateMethodResponse(client, params) {
  // Create or update a method response.
  try {
    await client.send(new PutMethodResponseCommand(params))
  } catch (error) {
    if (!isAlreadyExistsError(error))
      throw error
    const { restApiId, resourceId, httpMethod, statusCode, responseParameters } = params
    await client.send(new UpdateMethodResponseCommand({
      restApiId,
      resourceId,
      httpMethod,
      statusCode,
      patchOperations: responseParameterPatches(responseParameters),
    }))
  }
}

async function putOrUpdateIntegrationResponse(client, params) {
  // Create or update an integration response.
  try {
    await client.send(new PutIntegrationResponseCommand(params))
  } catch (error) {
    if (!isAlreadyExistsError(error))
      throw error
    const { restApiId, resourceId, httpMethod, statusCode, responseParameters } = params
    await client.send(new UpdateIntegrationResponseCommand({
      restApiId,
      resourceId,
      httpMethod,
      statusCode,
      patchOperations: responseParameterPatches(responseParameters),
    }))
  }
}

async function ensureCorsOptionsMethod(client, restApiId, resourceId) {
  // Add OPTIONS /subscriptions so browsers can preflight cross-origin POSTs.
  const httpMethod = 'OPTIONS'
  if (await methodExists(client, restApiId, resourceId, httpMethod)) {
    console.log('OPTIONS /subscriptions already exists.')
  } else {
    console.log('Creating OPTIONS /subscriptions for CORS.')
    await client.send(new PutMethodCommand({
      restApiId,
      resourceId,
      httpMethod,
      authorizationType: 'NONE',
    }))
  }

  await client.send(new PutIntegrationCommand({
    restApiId,
    resourceId,
    httpMethod,
    type: 'MOCK',
    requestTemplates: {
      'application/json': '{"statusCode": 200}',
    },
  }))

  const methodResponse = {
    restApiId,
    resourceId,
    httpMethod,
    statusCode: '200',
    responseParameters: {
      'method.response.header.Access-Control-Allow-Headers': true,
      'method.response.header.Access-Control-Allow-Methods': true,
      'method.response.header.Access-Control-Allow-Origin': true,
    },
  }
  await putOrUpdateMethodResponse(client, methodResponse)

  const integrationResponse = {
    restApiId,
    resourceId,
    httpMethod,
    statusCode: '200',
    responseParameters: {
      'method.response.header.Access-Control-Allow-Headers':
        "'Content-Type,Authorization'",
      'method.response.header.Access-Control-Allow-Methods':
        "'POST,OPTIONS'",
      'method.response.header.Access-Control-Allow-Origin': "'*'",
    },
  }
  await putOrUpdateIntegrationResponse(client, integrationResponse)
}

const GATEWAY_CORS_RESPONSE_TYPES = [
  'DEFAULT_4XX',
  'DEFAULT_5XX',
  'UNAUTHORIZED',
  'ACCESS_DENIED',
  'MISSING_AUTHENTICATION_TOKEN',
  'EXPIRED_TOKEN',
  'INVALID_SIGNATURE',
]

const GATEWAY_CORS_PARAMETERS = {
  'gatewayresponse.header.Access-Control-Allow-Origin': "'*'",
  'gatewayresponse.header.Access-Control-Allow-Headers': "'Content-Type,Authorization'",
  'gatewayresponse.header.Access-Control-Allow-Methods': "'POST,OPTIONS'",
}

async function putOrUpdateGatewayResponse(client, params) {
  // Create or update a gateway response with CORS headers.
  try {
    await client.send(new PutGatewayResponseCommand(params))
  } catch (error) {
    if (!isAlreadyExistsError(error))
      throw error
    const { restApiId, responseType, responseParameters } = params
    await client.send(new UpdateGatewayResponseCommand({
      restApiId,
      responseType,
      patchOperations: responseParameterPatches(responseParameters),
    }))
  }
}

async function ensureGatewayCorsResponses(client, restApiId) {
  // Add CORS headers to API Gateway error responses (e.g. 401 from Cognito).
  for (const responseType of GATEWAY_CORS_RESPONSE_TYPES) {
    await putOrUpdateGatewayResponse(client, {
      restApiId,
      responseType,
      responseParameters: GATEWAY_CORS_PARAMETERS,
    })
  }
  console.log('Gateway error responses configured for CORS.')
}

function invokeUrl(region, restApiId) {
  // Return the stage invoke URL for POST /subscriptions.
  return `https://${restApiId}.execute-api.${region}.amazonaws.com/${API_STAGE}/${API_RESOURCE}`
}

async function configureApiGateway(region) {
  // Create the API Gateway REST API used to save subscriptions.
  const settings = loadAwsSettings()
  const accountId = await getAccountId(region)
  const userPoolArn =
    `arn:aws:cognito-idp:${region}:${accountId}:userpool/${settings.userPoolId}`
  const client = apiGatewayClient(region)

  const api = await findOrCreateRestApi(client)
  const authorizer = await findOrCreateAuthorizer(client, api.id, userPoolArn)
  const resource = await findOrCreateSubscriptionsResource(client, api.id)
  await ensurePostSubscriptionsMethod(client, api.id, resource.id, authorizer.id)
  await ensureCorsOptionsMethod(client, api.id, resource.id)
  await ensureGatewayCorsResponses(client, api.id)

  console.log(`Deploying API to stage ${API_STAGE}.`)
  await client.send(new CreateDeploymentCommand({
    restApiId: api.id,
    stageName: API_STAGE,
    description: 'collections push subscriptions',
  }))

  const url = invokeUrl(region, api.id)
  console.log(`API Gateway ready: POST ${url}`)
  console.log('Run: scripts/notification --deploy save-subscription')
  return url
}

async function configure() {
  // Create the DynamoDB table and API Gateway for push subscriptions.
  const region = loadAwsRegion()
  await configureDynamoTable(region)
  const url = await configureApiGateway(region)
  updateAwsSettingsSubscriptionsUrl(url)
}

async function findSubscriptionsApiUrl(region) {
  // Return the invoke URL for the push subscriptions API.
  const client = apiGatewayClient(region)
  const api = await findRestApi(client, API_NAME)
  errorExit(!api,
    `API Gateway ${API_NAME} not found. Run: scripts/notification --configure`)
  return invokeUrl(region, api.id)
}

function formatUpdatedAt(iso) {
  // Format an ISO timestamp as "YYYY-MM-DD HH:MM:SS".
  if (!iso)
    return '????-??-?? ??:??:??'
  return iso.replace('T', ' ').replace(/\.\d+Z?$/, '').replace(/Z$/, '')
}

function shortEndpoint(endpoint) {
  // Return a short recognizable prefix of a push endpoint URL.
  try {
    const url = new URL(endpoint)
    const parts = url.pathname.split('/').filter(Boolean)
    if (parts.length <= 1)
      return `${url.origin}/...`
    return `${url.origin}/${parts.slice(0, 2).join('/')}/...`
  } catch {
    return `${String(endpoint).slice(0, 40)}...`
  }
}

async function scanSubscriptions() {
  // Return all push subscription items from DynamoDB.
  const client = docClient(loadAwsRegion())
  const items = []
  let lastKey
  do {
    const response = await client.send(new ScanCommand({
      TableName: TABLE_NAME,
      ExclusiveStartKey: lastKey,
    }))
    items.push(...(response.Items ?? []))
    lastKey = response.LastEvaluatedKey
  } while (lastKey)
  return items
}

async function getSubscriptions(mode) {
  // List subscriptions one per line, or as detailed JSON.
  const items = await scanSubscriptions()

  if (mode === 'json') {
    console.log(JSON.stringify(items, null, 2))
    return
  }

  if (mode !== true)
    exit1(`Unknown --get-subscriptions mode: ${mode}. Use json or omit.`)

  // Sort by the time the subscription was added.
  items.sort((a, b) => String(b.updatedAt ?? '').localeCompare(String(a.updatedAt ?? '')))

  // Show one subscription per line.  Each line has date, user id, and
  // a short endpoint.
  for (const item of items) {
    console.log(
      `${formatUpdatedAt(item.updatedAt)} ${item.userId} ${shortEndpoint(item.endpoint)}`
    )
  }
}

async function saveSubscription(file) {
  // POST a subscription through API Gateway to the save-subscription Lambda.
  const data = loadSubscriptionFile(file)
  const accessToken = loadAccessToken()
  const tokenUserId = tokenUserIdFromAccessToken(accessToken)
  errorExit(data.userId !== tokenUserId,
    `Subscription userId (${data.userId}) does not match token user (${tokenUserId}).`)
  const url = await findSubscriptionsApiUrl(loadAwsRegion())

  const body = {
    userId: data.userId,
    endpoint: data.endpoint,
    keys: {
      p256dh: data.keys.p256dh,
      auth: data.keys.auth,
    },
  }

  const response = await fetch(url, {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${accessToken}`,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify(body),
  })

  const text = await response.text()
  if (!response.ok) {
    let message = `Failed to save subscription: ${response.status} ${response.statusText}`
    if (text)
      message += `\n${text}`
    exit1(message)
  }

  console.log(`Saved subscription for user ${data.userId}.`)
  if (text)
    console.log(text)
}

async function sendPushNotification(subscription, subject, title, body) {
  // Send one push notification using web-push and VAPID keys.
  const vapid = loadVapidCredentials()

  const payload = JSON.stringify({
    title: title || '',
    body: body || '',
  })

  webPush.setVapidDetails(
    vapidSubject(subject),
    vapid.public,
    vapid.private,
  )

  await webPush.sendNotification(subscription, payload)
}

async function sendPush(file) {
  // Send the push notification to the user.
  const { subscription, subject, title, body } = loadPushFile(file)

  errorExit(!subject, 'Push file is missing subject.')
  errorExit(!title && !body, 'Push file is missing title and/or body.')

  try {
    await sendPushNotification(subscription, subject, title, body)
    console.log('Push notification sent.')
  } catch (error) {
    if (subscription.userId && subscription.endpoint &&
        isExpiredSubscriptionError(error)) {
      await removeExpiredSubscription(subscription.userId, subscription.endpoint)
    }
    exit1(`Failed to send push notification: ${formatPushError(error)}`)
  }
}

function subscriptionsForUser(items, user) {
  // Return subscriptions for one user, or all when user is "all".
  if (user === 'all')
    return items
  return items.filter(item => item.userId === user)
}

async function publishNotifications(user, title) {
  // Send a collection publish notification to one user or all subscribers.
  errorExit(!user, '--publish requires a user id or all.')
  errorExit(!title, '--publish requires a collection title.')

  const subject = loadVapidSubject()
  const items = await scanSubscriptions()
  const targets = subscriptionsForUser(items, user)

  if (user === 'all') {
    errorExit(targets.length === 0, 'No push subscriptions found.')
  } else {
    errorExit(targets.length === 0, `No push subscriptions for user ${user}.`)
  }

  console.log(`Sending "${title}" to ${targets.length} subscription(s).`)

  let sent = 0
  let failed = 0
  let removed = 0
  for (const item of targets) {
    const subscription = {
      endpoint: item.endpoint,
      keys: item.keys,
    }
    try {
      await sendPushNotification(subscription, subject, title, '')
      sent += 1
      console.log(`Sent to ${item.userId} ${shortEndpoint(item.endpoint)}`)
    } catch (error) {
      failed += 1
      if (isExpiredSubscriptionError(error)) {
        await removeExpiredSubscription(item.userId, item.endpoint)
        removed += 1
      }
      console.error(
        `Failed for ${item.userId} ${shortEndpoint(item.endpoint)}: ` +
        `${formatPushError(error)}`
      )
    }
  }

  console.log(`Push notifications sent: ${sent}` +
    (failed ? `, failed: ${failed}` : '') +
    (removed ? `, removed: ${removed}` : '') + '.')
  if (sent === 0)
    exit1('All push notifications failed.')
}

function showVapidKeys() {
  // Generate and print new VAPID keys.
  const vapidKeys = webPush.generateVAPIDKeys()
  console.log(`Save VAPID keys to ${AWS_VAPID} and copy the public key to ts/notify.ts.
Do not add a [VAPID] section to ${AWS_CREDENTIALS}; boto3 cannot parse it.

[VAPID]
public = ${vapidKeys.publicKey}
private = ${vapidKeys.privateKey}
subject = your-email@example.com
`)
}

function lambdaDeployConfig(name) {
  // Return the deploy configuration for the named Lambda function.
  const config = LAMBDA_DEPLOYS[name]
  errorExit(!config,
    `Unknown Lambda function: ${name}. Available: ${Object.keys(LAMBDA_DEPLOYS).join(', ')}.`)
  return config
}

function lambdaNodeVersion(functionName) {
  // Read the node version from the function's make-js-lambda-zip script.
  const scriptPath =
    path.join(process.cwd(), 'env/lambda', functionName, 'make-js-lambda-zip')
  const text = readFile(scriptPath)
  const match = text.match(/^version=(\S+)/m)
  errorExit(!match, `Unable to read node version from ${scriptPath}.`)
  return match[1]
}

function lambdaRuntime(functionName) {
  // Return the Lambda runtime that matches the function's node version.
  const major = lambdaNodeVersion(functionName).split('.')[0]
  return `nodejs${major}.x`
}

function lambdaZipPath(functionName) {
  // Return the path to the built Lambda zip file.
  const version = lambdaNodeVersion(functionName)
  return path.join(
    process.cwd(), 'env/lambda', functionName, 'js', `lambda-js-${version}.zip`)
}

function loadLambdaZip(functionName) {
  // Read the Lambda zip file built by make-js-lambda-zip.
  const zipPath = lambdaZipPath(functionName)
  errorExit(!fs.existsSync(zipPath),
    `Zip file not found: ${zipPath}. Run tests, then: env/lambda/${functionName}/make-js-lambda-zip`)
  console.log(`Using zip file: ${zipPath}`)
  return fs.readFileSync(zipPath)
}

async function waitForLambdaActive(client, functionName) {
  // Wait until the Lambda function update completes.
  const { GetFunctionConfigurationCommand } = deploySdk()
  for (;;) {
    const response = await client.send(new GetFunctionConfigurationCommand({
      FunctionName: functionName,
    }))
    const { State, LastUpdateStatus, LastUpdateStatusReason } = response
    if (State === 'Active' && LastUpdateStatus === 'Successful')
      return response
    if (LastUpdateStatus === 'Failed')
      exit1(`Lambda update failed: ${LastUpdateStatusReason}`)
    console.log(`Lambda status: ${LastUpdateStatus ?? State}. Waiting...`)
    await new Promise(resolve => setTimeout(resolve, 2000))
  }
}

async function loadLambdaExecutionRole() {
  // Return the Lambda execution role ARN configured in the IAM console.
  const { GetRoleCommand } = deploySdk()
  const client = iamClient()
  try {
    const response = await client.send(new GetRoleCommand({
      RoleName: LAMBDA_EXECUTION_ROLE,
    }))
    return response.Role.Arn
  } catch (error) {
    if (error.name !== 'NoSuchEntityException')
      throw error
    exit1(`Lambda execution role ${LAMBDA_EXECUTION_ROLE} not found. ` +
      'Create it in the IAM console. See docs/aws-config.md.')
  }
}

async function createOrUpdateLambda(region, config, roleArn, zipFile) {
  // Create or update the Lambda function code.
  const {
    GetFunctionCommand,
    UpdateFunctionCodeCommand,
    CreateFunctionCommand,
  } = deploySdk()
  const client = lambdaClient(region)
  const { functionName } = config
  let exists = false
  try {
    await client.send(new GetFunctionCommand({ FunctionName: functionName }))
    exists = true
  } catch (error) {
    if (error.name !== 'ResourceNotFoundException')
      throw error
  }

  if (exists) {
    console.log(`Updating Lambda function ${functionName}.`)
    await client.send(new UpdateFunctionCodeCommand({
      FunctionName: functionName,
      ZipFile: zipFile,
    }))
  } else {
    console.log(`Creating Lambda function ${functionName}.`)
    await client.send(new CreateFunctionCommand({
      FunctionName: functionName,
      Runtime: lambdaRuntime(functionName),
      Role: roleArn,
      Handler: config.handler,
      Description: config.description,
      Code: { ZipFile: zipFile },
      Timeout: 10,
    }))
  }

  const updated = await waitForLambdaActive(client, functionName)
  console.log(`Lambda function ready: ${updated.FunctionArn}`)
  return updated.FunctionArn
}

async function findApiResource(client, restApiId, resourcePath) {
  // Return the API Gateway resource with the given path.
  const response = await client.send(new GetResourcesCommand({
    restApiId,
    limit: 500,
  }))
  return (response.items ?? []).find(item => item.path === resourcePath)
}

async function ensureLambdaInvokePermission(region, functionName, restApiId, integration) {
  // Allow API Gateway to invoke the Lambda function.
  const { AddPermissionCommand } = deploySdk()
  const client = lambdaClient(region)
  const accountId = await getAccountId(region)
  const sourceArn =
    `arn:aws:execute-api:${region}:${accountId}:${restApiId}/*/` +
    `${integration.httpMethod}${integration.resourcePath}`
  const statementId = `apigateway-${restApiId}-${integration.httpMethod}-subscriptions`
  try {
    await client.send(new AddPermissionCommand({
      FunctionName: functionName,
      StatementId: statementId,
      Action: 'lambda:InvokeFunction',
      Principal: 'apigateway.amazonaws.com',
      SourceArn: sourceArn,
    }))
    console.log('Added API Gateway invoke permission for Lambda.')
  } catch (error) {
    if (error.name !== 'ResourceConflictException')
      throw error
    console.log('API Gateway invoke permission already exists.')
  }
}

async function wireLambdaIntegration(region, config, functionArn) {
  // Connect API Gateway POST /subscriptions to the Lambda function.
  const client = apiGatewayClient(region)
  const api = await findRestApi(client, API_NAME)
  errorExit(!api,
    `API Gateway ${API_NAME} not found. Run: scripts/notification --configure`)
  const integration = config.apiIntegration
  const resource = await findApiResource(client, api.id, integration.resourcePath)
  errorExit(!resource,
    `API Gateway resource ${integration.resourcePath} not found.`)

  await ensureCorsOptionsMethod(client, api.id, resource.id)
  await ensureGatewayCorsResponses(client, api.id)

  const uri =
    `arn:aws:apigateway:${region}:lambda:path/2015-03-31/functions/${functionArn}/invocations`
  console.log(`Wiring ${integration.httpMethod} ${integration.resourcePath} to Lambda.`)
  await client.send(new PutIntegrationCommand({
    restApiId: api.id,
    resourceId: resource.id,
    httpMethod: integration.httpMethod,
    type: 'AWS_PROXY',
    integrationHttpMethod: 'POST',
    uri,
  }))

  await ensureLambdaInvokePermission(region, config.functionName, api.id, integration)

  console.log(`Deploying API to stage ${API_STAGE}.`)
  await client.send(new CreateDeploymentCommand({
    restApiId: api.id,
    stageName: API_STAGE,
    description: `wire ${config.functionName}`,
  }))

  const url = invokeUrl(region, api.id)
  console.log(`API Gateway ready: ${integration.httpMethod} ${url}`)
}

async function deployLambda(name) {
  // Deploy and wire a notification Lambda function from a built zip file.
  const config = lambdaDeployConfig(name)
  const region = loadAwsRegion()
  const zipFile = loadLambdaZip(name)
  const roleArn = await loadLambdaExecutionRole()
  const functionArn = await createOrUpdateLambda(region, config, roleArn, zipFile)
  if (config.apiIntegration)
    await wireLambdaIntegration(region, config, functionArn)
}

async function main() {
  // Run the command specified on the command line.
  program.parse(process.argv)
  const options = program.opts()
  if (options.vapid) {
    showVapidKeys()
  } else if (options.push) {
    await sendPush(options.push)
  } else if (options.publish) {
    const args = options.publish
    const user = Array.isArray(args) ? args[0] : args
    const title = Array.isArray(args) ? args[1] : undefined
    await publishNotifications(user, title)
  } else if (options.save) {
    await saveSubscription(options.save)
  } else if (options.configure) {
    await configure()
  } else if (options.getSubscriptions !== undefined) {
    await getSubscriptions(options.getSubscriptions)
  } else if (options.deploy) {
    await deployLambda(options.deploy)
  } else {
    console.log('Run with -h to see the available options.')
  }
}

main().catch(error => {
  exit1(error.message)
})
