#!/usr/bin/env node

"use strict"

// Work with Push Subscriptions
//
// Run from the collections container:
//
// cd ~/collections
// scripts/notification -h
//
// Web Push Docs:
// https://developer.mozilla.org/en-US/docs/Web/API/Push_API
// https://web.dev/articles/push-notifications-overview
//
// Push JSON file (-p/--push <file>):
//
//   endpoint       (required) Push service URL from PushSubscription.toJSON()
//   keys           (required) object with:
//     p256dh       (required) client public key
//     auth         (required) authentication secret
//   subject        (required) contact email for the VAPID subject
//   title          notification title (at least one of title or body required)
//   body           notification body (at least one of title or body required)
//
// Subscription JSON file (-s/--save <file>):
//
//   userId         (required) Cognito user id
//   endpoint       (required) Push service URL
//   keys           (required) object with p256dh and auth
//
// Auth for --save:
//
//   Authorization Bearer token from tmp/tokens.json (access_token).
//   Create tokens with: scripts/login-flow -g <code> or -r
//
// VAPID keys (~/.aws/credentials, [VAPID] section):
//
//   public: VAPID public key (must match the key used when creating the subscription)
//   private: VAPID private key
//
// DynamoDB:
//
//   table name = TABLE_NAME constant below
//   region     = region from ~/.aws/config [default] section
//
// API Gateway (created by --configure):
//
//   REST API name = API_NAME
//   POST /subscriptions with Cognito authorizer (MOCK until Lambda)

if (!process.env.coder_env) {
  console.log("Run from the Collection's docker environment.")
  exit1()
}

const fs = require('fs')
const os = require('os')
const path = require('path')
const webPush = require('web-push')
const { Command } = require('commander')
const {
  CreateTableCommand,
  DescribeTableCommand,
  DynamoDBClient,
} = require('@aws-sdk/client-dynamodb')
const {
  DynamoDBDocumentClient,
  ScanCommand,
} = require('@aws-sdk/lib-dynamodb')
const {
  APIGatewayClient,
  CreateAuthorizerCommand,
  CreateDeploymentCommand,
  CreateResourceCommand,
  CreateRestApiCommand,
  GetAuthorizersCommand,
  GetMethodCommand,
  GetResourcesCommand,
  GetRestApisCommand,
  PutIntegrationCommand,
  PutIntegrationResponseCommand,
  PutMethodCommand,
  PutMethodResponseCommand,
} = require('@aws-sdk/client-api-gateway')
const {
  STSClient,
  GetCallerIdentityCommand,
} = require('@aws-sdk/client-sts')

const AWS_CREDENTIALS = path.join(os.homedir(), '.aws', 'credentials')
const AWS_CONFIG = path.join(os.homedir(), '.aws', 'config')
const AWS_SETTINGS = path.join(process.cwd(), 'env', 'aws-settings.json')
const TOKENS_FILE = path.join(process.cwd(), 'tmp', 'tokens.json')
const TABLE_NAME = 'collections-push-subscriptions'
const API_NAME = 'collections-push-subscriptions'
const API_STAGE = 'prod'
const API_RESOURCE = 'subscriptions'
const API_AUTH_SCOPE = 'aws.cognito.signin.user.admin'

const program = new Command()
program
  .option('-v, --vapid',
    'Generate VAPID public and private keys used to send push notifications.')
  .option('-p, --push <file>',
    'Send a push notification.')
  .option('-s, --save <file>',
    'Save a push subscription via API Gateway using the JWT in tmp/tokens.json.')
  .option('--configure',
    'Create the DynamoDB table and API Gateway for push subscriptions.')
  .option('-g, --get-subscriptions [json]',
    'List push subscriptions one per line. Use json for listing them in JSON format with more details.')

function exit1(message) {
  // Exit the process with a return code of 1.
  if (message)
    console.error(message)
  process.exit(1)
}

function readFile(filename, errorMessage) {
  // Read the file. If there is an error, log the message to the
  // console and exit the process.
  try {
    return fs.readFileSync(filename, 'utf8')
  } catch (error) {
    if (!errorMessage)
      errorMessage = `Unable to read ${filename}.`
    exit1(errorMessage)
  }
}

function parseIniSection(text, sectionName) {
  // Return the key value pairs from the named section of an ini file.
  // Supports both "key: value" and "key = value" forms.
  const values = {}
  let inSection = false
  for (const line of text.split('\n')) {
    if (/^\[/.test(line)) {
      inSection = line.trim().toLowerCase() === `[${sectionName.toLowerCase()}]`
      continue
    }
    if (!inSection)
      continue
    const match = line.match(/^\s*([^=:\s]+)\s*[:=]\s*(.+)\s*$/)
    if (match)
      values[match[1]] = match[2].trim()
  }
  return values
}

function loadVapidCredentials() {
  // Read the VAPID keys from the [VAPID] section of ~/.aws/credentials.
  // Return an object with the public and private key values.
  const text = readFile(AWS_CREDENTIALS,
    `Unable to read ${AWS_CREDENTIALS}. Add a [VAPID] section.`)
  const credentials = parseIniSection(text, 'VAPID')
  if (!credentials.public || !credentials.private)
    exit1(`${AWS_CREDENTIALS} is missing a [VAPID] section with public and private keys.`)
  return credentials
}

function loadAwsRegion() {
  // Read the region from the [default] section of ~/.aws/config.
  const text = readFile(AWS_CONFIG,
    `Unable to read ${AWS_CONFIG}. Run aws configure to set the region.`)
  const config = parseIniSection(text, 'default')
  if (!config.region)
    exit1(`${AWS_CONFIG} is missing region in the [default] section.`)
  return config.region
}

function loadAwsSettings() {
  // Read Cognito settings from env/aws-settings.json.
  const data = JSON.parse(readFile(AWS_SETTINGS,
    `Unable to read ${AWS_SETTINGS}. Run: scripts/cognito -w`))
  errorExit(!data.settings?.userPoolId,
    `${AWS_SETTINGS} is missing settings.userPoolId.`)
  errorExit(!data.settings?.client_id,
    `${AWS_SETTINGS} is missing settings.client_id.`)
  return data.settings
}

function loadAccessToken() {
  // Read the Cognito access token from tmp/tokens.json.
  const data = JSON.parse(readFile(TOKENS_FILE,
    `Unable to read ${TOKENS_FILE}. Run: scripts/login-flow -g <code> or -r`))
  errorExit(!data.access_token,
    `${TOKENS_FILE} is missing access_token.`)
  return data.access_token
}

function errorExit(condition, errorMessage) {
  // If the condition is true, show the error message and exit.
  if (condition)
    exit1(errorMessage)
}

function loadPushFile(file) {
  // Read the push JSON file and return an object containing its
  // values. If an error happens, show an error message and exit.
  const data = JSON.parse(readFile(file))

  errorExit(!data.endpoint, 'Push file is missing endpoint.')
  errorExit(!data.keys?.p256dh, 'Push file is missing keys.p256dh.')
  errorExit(!data.keys?.auth, 'Push file is missing keys.auth.')

  const { subject, title, body, ...subscription } = data
  return { subscription, subject, title, body }
}

function loadSubscriptionFile(file) {
  // Read the subscription JSON file and return its values. If an
  // error happens, show an error message and exit.
  const data = JSON.parse(readFile(file))

  errorExit(!data.userId, 'Subscription file is missing userId.')
  errorExit(!data.endpoint, 'Subscription file is missing endpoint.')
  errorExit(!data.keys?.p256dh, 'Subscription file is missing keys.p256dh.')
  errorExit(!data.keys?.auth, 'Subscription file is missing keys.auth.')

  return data
}

function dynamoClient(region) {
  // Return a DynamoDB client for the given region.
  return new DynamoDBClient({ region })
}

function docClient(region) {
  // Return a DynamoDB document client for the given region.
  return DynamoDBDocumentClient.from(dynamoClient(region))
}

function apiGatewayClient(region) {
  // Return an API Gateway client for the given region.
  return new APIGatewayClient({ region })
}

async function getAccountId(region) {
  // Return the AWS account id for the current credentials.
  const sts = new STSClient({ region })
  const response = await sts.send(new GetCallerIdentityCommand({}))
  return response.Account
}

function vapidSubject(email) {
  // Return the VAPID subject, adding mailto: when needed.
  return email.includes(':') ? email : `mailto:${email}`
}

function formatPushError(error) {
  // Return a formatted error message from a web-push error.
  let message = error.message
  if (error.statusCode)
    message += ` (${error.statusCode})`
  if (error.body)
    message += `\n${error.body}`
  return message
}

async function waitForTableActive(client, tableName) {
  // Wait until the DynamoDB table status is ACTIVE.
  for (;;) {
    const response = await client.send(new DescribeTableCommand({ TableName: tableName }))
    const status = response.Table?.TableStatus
    if (status === 'ACTIVE') {
      console.log('Table is active.')
      return
    }
    console.log(`Table status: ${status}. Waiting...`)
    await new Promise(resolve => setTimeout(resolve, 2000))
  }
}

async function configureDynamoTable(region) {
  // Create the DynamoDB table for push subscriptions if needed.
  const client = dynamoClient(region)

  try {
    await client.send(new DescribeTableCommand({ TableName: TABLE_NAME }))
    console.log(`Table ${TABLE_NAME} already exists.`)
  } catch (error) {
    if (error.name !== 'ResourceNotFoundException')
      throw error

    console.log(`Creating table ${TABLE_NAME} in ${region}.`)
    await client.send(new CreateTableCommand({
      TableName: TABLE_NAME,
      KeySchema: [
        { AttributeName: 'userId', KeyType: 'HASH' },
        { AttributeName: 'endpoint', KeyType: 'RANGE' },
      ],
      AttributeDefinitions: [
        { AttributeName: 'userId', AttributeType: 'S' },
        { AttributeName: 'endpoint', AttributeType: 'S' },
      ],
      BillingMode: 'PAY_PER_REQUEST',
    }))
    await waitForTableActive(client, TABLE_NAME)
  }
}

async function findRestApi(client, name) {
  // Return the REST API with the given name, or null.
  let position
  do {
    const response = await client.send(new GetRestApisCommand({
      limit: 500,
      position,
    }))
    const match = (response.items ?? []).find(api => api.name === name)
    if (match)
      return match
    position = response.position
  } while (position)
  return null
}

async function findOrCreateRestApi(client) {
  // Return the push subscriptions REST API, creating it if needed.
  const existing = await findRestApi(client, API_NAME)
  if (existing) {
    console.log(`API Gateway ${API_NAME} already exists (${existing.id}).`)
    return existing
  }

  console.log(`Creating API Gateway REST API ${API_NAME}.`)
  return client.send(new CreateRestApiCommand({
    name: API_NAME,
    description: 'Save Web Push subscriptions for Collections.',
    endpointConfiguration: { types: ['REGIONAL'] },
  }))
}

async function findOrCreateAuthorizer(client, restApiId, userPoolArn) {
  // Return the Cognito authorizer for the API, creating it if needed.
  const response = await client.send(new GetAuthorizersCommand({
    restApiId,
    limit: 100,
  }))
  const existing = (response.items ?? []).find(item => item.name === 'cognito')
  if (existing) {
    console.log(`Cognito authorizer already exists (${existing.id}).`)
    return existing
  }

  console.log('Creating Cognito authorizer.')
  return client.send(new CreateAuthorizerCommand({
    restApiId,
    name: 'cognito',
    type: 'COGNITO_USER_POOLS',
    providerARNs: [userPoolArn],
    identitySource: 'method.request.header.Authorization',
  }))
}

async function findOrCreateSubscriptionsResource(client, restApiId) {
  // Return the /subscriptions resource, creating it if needed.
  const response = await client.send(new GetResourcesCommand({
    restApiId,
    limit: 500,
  }))
  const resources = response.items ?? []
  const existing = resources.find(item => item.path === `/${API_RESOURCE}`)
  if (existing) {
    console.log(`Resource /${API_RESOURCE} already exists.`)
    return existing
  }

  const root = resources.find(item => item.path === '/')
  errorExit(!root, 'API Gateway root resource not found.')

  console.log(`Creating resource /${API_RESOURCE}.`)
  return client.send(new CreateResourceCommand({
    restApiId,
    parentId: root.id,
    pathPart: API_RESOURCE,
  }))
}

async function methodExists(client, restApiId, resourceId, httpMethod) {
  // Return true if the method already exists on the resource.
  try {
    await client.send(new GetMethodCommand({
      restApiId,
      resourceId,
      httpMethod,
    }))
    return true
  } catch (error) {
    if (error.name === 'NotFoundException')
      return false
    throw error
  }
}

async function ensurePostSubscriptionsMethod(client, restApiId, resourceId, authorizerId) {
  // Create POST /subscriptions with Cognito auth and a MOCK integration.
  if (await methodExists(client, restApiId, resourceId, 'POST')) {
    console.log('POST /subscriptions already exists.')
    return
  }

  console.log('Creating POST /subscriptions with Cognito authorizer (MOCK integration).')
  await client.send(new PutMethodCommand({
    restApiId,
    resourceId,
    httpMethod: 'POST',
    authorizationType: 'COGNITO_USER_POOLS',
    authorizerId,
    authorizationScopes: [API_AUTH_SCOPE],
  }))

  await client.send(new PutIntegrationCommand({
    restApiId,
    resourceId,
    httpMethod: 'POST',
    type: 'MOCK',
    requestTemplates: {
      'application/json': '{"statusCode": 200}',
    },
  }))

  await client.send(new PutMethodResponseCommand({
    restApiId,
    resourceId,
    httpMethod: 'POST',
    statusCode: '200',
    responseModels: {
      'application/json': 'Empty',
    },
  }))

  await client.send(new PutIntegrationResponseCommand({
    restApiId,
    resourceId,
    httpMethod: 'POST',
    statusCode: '200',
    responseTemplates: {
      'application/json':
        '{"ok":true,"message":"Subscription accepted (Lambda not wired yet)."}',
    },
  }))
}

function invokeUrl(region, restApiId) {
  // Return the stage invoke URL for POST /subscriptions.
  return `https://${restApiId}.execute-api.${region}.amazonaws.com/${API_STAGE}/${API_RESOURCE}`
}

async function configureApiGateway(region) {
  // Create the API Gateway REST API used to save subscriptions.
  const settings = loadAwsSettings()
  const accountId = await getAccountId(region)
  const userPoolArn =
    `arn:aws:cognito-idp:${region}:${accountId}:userpool/${settings.userPoolId}`
  const client = apiGatewayClient(region)

  const api = await findOrCreateRestApi(client)
  const authorizer = await findOrCreateAuthorizer(client, api.id, userPoolArn)
  const resource = await findOrCreateSubscriptionsResource(client, api.id)
  await ensurePostSubscriptionsMethod(client, api.id, resource.id, authorizer.id)

  console.log(`Deploying API to stage ${API_STAGE}.`)
  await client.send(new CreateDeploymentCommand({
    restApiId: api.id,
    stageName: API_STAGE,
    description: 'collections push subscriptions',
  }))

  const url = invokeUrl(region, api.id)
  console.log(`API Gateway ready: POST ${url}`)
  return url
}

async function configure() {
  // Create the DynamoDB table and API Gateway for push subscriptions.
  const region = loadAwsRegion()
  await configureDynamoTable(region)
  await configureApiGateway(region)
}

async function findSubscriptionsApiUrl(region) {
  // Return the invoke URL for the push subscriptions API.
  const client = apiGatewayClient(region)
  const api = await findRestApi(client, API_NAME)
  errorExit(!api,
    `API Gateway ${API_NAME} not found. Run: scripts/notification --configure`)
  return invokeUrl(region, api.id)
}

function formatUpdatedAt(iso) {
  // Format an ISO timestamp as "YYYY-MM-DD HH:MM:SS".
  if (!iso)
    return '????-??-?? ??:??:??'
  return iso.replace('T', ' ').replace(/\.\d+Z?$/, '').replace(/Z$/, '')
}

function shortEndpoint(endpoint) {
  // Return a short recognizable prefix of a push endpoint URL.
  try {
    const url = new URL(endpoint)
    const parts = url.pathname.split('/').filter(Boolean)
    if (parts.length <= 1)
      return `${url.origin}/...`
    return `${url.origin}/${parts.slice(0, 2).join('/')}/...`
  } catch {
    return `${String(endpoint).slice(0, 40)}...`
  }
}

async function scanSubscriptions() {
  // Return all push subscription items from DynamoDB.
  const client = docClient(loadAwsRegion())
  const items = []
  let lastKey
  do {
    const response = await client.send(new ScanCommand({
      TableName: TABLE_NAME,
      ExclusiveStartKey: lastKey,
    }))
    items.push(...(response.Items ?? []))
    lastKey = response.LastEvaluatedKey
  } while (lastKey)
  return items
}

async function getSubscriptions(mode) {
  // List subscriptions one per line, or as detailed JSON.
  const items = await scanSubscriptions()

  if (mode === 'json') {
    console.log(JSON.stringify(items, null, 2))
    return
  }

  if (mode !== true)
    exit1(`Unknown --get-subscriptions mode: ${mode}. Use json or omit.`)

  // Sort by the time the subscription was added.
  items.sort((a, b) => String(b.updatedAt ?? '').localeCompare(String(a.updatedAt ?? '')))

  // Show one subscription per line.  Each line has date, user id, and
  // a short endpoint.
  for (const item of items) {
    console.log(
      `${formatUpdatedAt(item.updatedAt)} ${item.userId} ${shortEndpoint(item.endpoint)}`
    )
  }
}

async function saveSubscription(file) {
  // POST a subscription to API Gateway using the Cognito access token.
  const data = loadSubscriptionFile(file)
  const accessToken = loadAccessToken()
  const url = await findSubscriptionsApiUrl(loadAwsRegion())

  const body = {
    userId: data.userId,
    endpoint: data.endpoint,
    keys: {
      p256dh: data.keys.p256dh,
      auth: data.keys.auth,
    },
  }

  const response = await fetch(url, {
    method: 'POST',
    headers: {
      Authorization: `Bearer ${accessToken}`,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify(body),
  })

  const text = await response.text()
  if (!response.ok) {
    let message = `Failed to save subscription: ${response.status} ${response.statusText}`
    if (text)
      message += `\n${text}`
    exit1(message)
  }

  console.log(`Saved subscription for user ${data.userId}.`)
  if (text)
    console.log(text)
}

async function sendPush(file) {
  // Send the push notification to the user.
  const { subscription, subject, title, body } = loadPushFile(file)
  const vapid = loadVapidCredentials()

  errorExit(!subject, 'Push file is missing subject.')
  errorExit(!title && !body, 'Push file is missing title and/or body.')

  const payload = JSON.stringify({
    title: title || '',
    body: body || '',
  })

  webPush.setVapidDetails(
    vapidSubject(subject),
    vapid.public,
    vapid.private,
  )

  try {
    await webPush.sendNotification(subscription, payload)
    console.log('Push notification sent.')
  } catch (error) {
    exit1(`Failed to send push notification: ${formatPushError(error)}`)
  }
}

function showVapidKeys() {
  // Generate and print new VAPID keys.
  const vapidKeys = webPush.generateVAPIDKeys()
  console.log(`Add a [VAPID] section to ${AWS_CREDENTIALS} and save the public key to ts/notify.ts:

[VAPID]
public: ${vapidKeys.publicKey}
private: ${vapidKeys.privateKey}
`)
}

async function main() {
  // Run the command specified on the command line.
  program.parse(process.argv)
  const options = program.opts()
  if (options.vapid) {
    showVapidKeys()
  } else if (options.push) {
    await sendPush(options.push)
  } else if (options.save) {
    await saveSubscription(options.save)
  } else if (options.configure) {
    await configure()
  } else if (options.getSubscriptions !== undefined) {
    await getSubscriptions(options.getSubscriptions)
  } else {
    console.log('Run with -h to see the available options.')
  }
}

main().catch(error => {
  exit1(error.message)
})
